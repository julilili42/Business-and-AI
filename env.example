# ============================================================
# Quoting Pipeline — Environment Template
# Kopiere nach ".env" und trage echte Werte ein.
# ".env" gehört NICHT ins Repo.
# ============================================================

# ----------------------------
# LLM provider
# ----------------------------
# "gemini" oder "azure"
LLM_PROVIDER=gemini

LLM_MAX_RETRIES=3
LLM_TIMEOUT_S=120

# ----------------------------
# Gemini  (nur wenn LLM_PROVIDER=gemini)
# ----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------
# Azure OpenAI / Nexus  (nur wenn LLM_PROVIDER=azure)
# ----------------------------
NEXUS_API_KEY=
AZURE_OPENAI_ENDPOINT=https://genai-nexus.api.corpinter.net/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-5-mini

# ----------------------------
# Paths
# Windows-Beispiel:  OUTPUT_DIR=C:\Business & AI\Output
# Relatives Beispiel: OUTPUT_DIR=./output
# ----------------------------
OUTPUT_DIR=./output
DATA_DIR=./data

# ----------------------------
# Matching thresholds (rapidfuzz, 0..100)
# ----------------------------
FUZZY_THRESHOLD=85
SEMANTIC_THRESHOLD=70

# ----------------------------
# PDF rendering DPI for vision-LLM input
# ----------------------------
PDF_RENDER_DPI=200

# ============================================================
# Outlook Add-in flow only — kannst du leerlassen, wenn du nur
# CLI oder Streamlit nutzt.
# ============================================================

# Lokales Bind für die FastAPI (run_review_api.py)
QUOTING_API_HOST=127.0.0.1
QUOTING_API_PORT=8000

# Wenn gesetzt: cloudflared wird NICHT gestartet (nur uvicorn)
# QUOTING_DISABLE_TUNNEL=1

# Fallback-URL, falls .tunnel_url nicht existiert.
# Im Normalfall NICHT manuell setzen — run_review_api.py schreibt
# die aktuelle Tunnel-URL automatisch nach .tunnel_url, und die
# FastAPI liest sie pro Request.
# API_BASE_URL=

# Streamlit Review-UI URL (für review_url im API-Response)
STREAMLIT_BASE_URL=http://localhost:8501

# Optional: cloudflared binary / config überschreiben
# CLOUDFLARED_BIN=cloudflared
# CLOUDFLARED_CONFIG=~/.cloudflared/config.yml
